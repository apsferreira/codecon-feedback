FROM golang:1.24-alpine AS builder

WORKDIR /app

# Dependências
COPY backend/go.mod backend/go.sum ./
RUN go mod download

# Código fonte
COPY backend/ .

RUN CGO_ENABLED=0 GOOS=linux go build -o /vote-ai-backend ./cmd/server

FROM alpine:3.20

RUN apk add --no-cache ca-certificates tzdata

WORKDIR /app

COPY --from=builder /vote-ai-backend .

EXPOSE 8080

CMD ["./vote-ai-backend"]
